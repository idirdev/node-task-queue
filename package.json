{
  "name": "node-task-queue",
  "version": "1.0.0",
  "description": "Background task queue system for Node.js with priority support, retries, scheduling, and middleware",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "example": "ts-node examples/basic.ts",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "keywords": [
    "task-queue",
    "background-jobs",
    "worker",
    "scheduler",
    "retry",
    "priority-queue"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0"
  }
}
